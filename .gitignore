# Environment (contains API keys)
.env

# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
*.egg

# IDE
.vscode/
.idea/

# Testing
.pytest_cache/
htmlcov/
.coverage

# OS
.DS_Store
Thumbs.db

# Local crash / temp
hs_err_pid*
*.log
.tmp_*
~$*.docx

# Local usage/output scratch
loot/

# Local analysis/cache artifacts
pyghidra_mcp_projects/

# Firmware policy for GitHub upload:
# keep microbench, ground-truth metadata, and eval manifests; exclude large firmware corpora/source mirrors
firmware/*
!firmware/microbench/
!firmware/microbench/**
!firmware/microbench_autogen/
!firmware/microbench_autogen/**
!firmware/ground_truth_bundle/
firmware/ground_truth_bundle/*
!firmware/ground_truth_bundle/*.json
!firmware/ground_truth_bundle/*.csv
!firmware/ground_truth_bundle/*.md
!firmware/ground_truth_bundle/microbench/
!firmware/ground_truth_bundle/microbench/**
!firmware/ground_truth_bundle/microbench_autogen/
!firmware/ground_truth_bundle/microbench_autogen/**
!firmware/ground_truth_bundle/mesobench/
!firmware/ground_truth_bundle/mesobench/**
!firmware/ground_truth_bundle/gt_backed_suite/
!firmware/ground_truth_bundle/gt_backed_suite/**
!firmware/ground_truth_bundle/references/
firmware/ground_truth_bundle/references/*
!firmware/ground_truth_bundle/references/mesobench/
!firmware/ground_truth_bundle/references/mesobench/**
!firmware/eval_suite/
firmware/eval_suite/*
!firmware/eval_suite/*manifest.json
!firmware/eval_suite/sample_catalog.json
!firmware/eval_suite/sample_catalog.csv

# Ignore nested Git metadata if any path gets included
**/.git

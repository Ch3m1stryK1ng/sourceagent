# SourceAgent Configuration
# Copy this file to .env and fill in your values

# API Keys (at least one required for LLM proposer stage)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# LLM Model (any LiteLLM-supported model)
# OpenAI: gpt-5.2, gpt-4.1, gpt-4.1-mini, o3, o4-mini
# Anthropic: claude-opus-4-6, claude-sonnet-4-5-20250929
# Google: gemini/gemini-2.5-flash (requires gemini/ prefix)
SOURCEAGENT_MODEL=gpt-4.1

# Agent Settings
SOURCEAGENT_AGENT_MAX_ITERATIONS=90
SOURCEAGENT_DEBUG=false

# Ghidra Integration (required for Stage 2+ pipeline)
LAUNCH_GHIDRA=1
GHIDRA_INSTALL_DIR=/path/to/ghidra
JAVA_HOME=/path/to/jdk

# Observability (optional)
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=https://cloud.langfuse.com
